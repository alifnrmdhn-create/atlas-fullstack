APP_NAME=ATLAS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
# Production: LOG_LEVEL=warning, LOG_CHANNEL=stderr (Railway capture stdout/stderr),
# dan LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter agar log terstruktur
# JSON + konteks request (request_id/user_id/path dari LogRequestContext) bisa
# di-query. Lokal biarkan default (line formatter, lebih enak dibaca).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# ── Database (PostgreSQL wajib) ───────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=atlas
DB_USERNAME=postgres
DB_PASSWORD=
DB_SCHEMA=public

# ── Session ───────────────────────────────────────────────────────────────────
# Default 'database' (config/session.php). Wajib di environment dengan filesystem
# ephemeral (Railway, Docker, k8s) — file sessions hilang per redeploy.
# Override ke 'file' hanya di dev untuk debug cepat.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# ── Filesystem ────────────────────────────────────────────────────────────────
# Evidence upload disimpan di storage/app/assignments/ (disk=local)
# Production: pastikan storage/app/ dapat ditulis oleh web server
FILESYSTEM_DISK=local

# ── Queue ─────────────────────────────────────────────────────────────────────
# Production: QUEUE_CONNECTION=database (php artisan queue:table && migrate)
# sync = blocking, tidak cocok untuk production yang ada job berat
QUEUE_CONNECTION=sync

# ── Cache ─────────────────────────────────────────────────────────────────────
# Production MULTI-REPLICA: CACHE_STORE=database (gratis, shared via Postgres —
#   WAJIB; file cache per-container bikin cache scope/authz tak konsisten +
#   onOneServer scheduler tak jalan). Upgrade Redis (lebih cepat) = config-flip.
# Single-replica saja: CACHE_STORE=file juga OK.
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Set ke `false` hanya saat dev lokal dengan `php artisan serve` (single worker
# habis kalau dipakai SSE long-lived). Production (FrankenPHP/Railway) wajib
# `true` supaya badge LIVE muncul dan delivery sub-detik aktif.
VITE_REALTIME_SSE=true
