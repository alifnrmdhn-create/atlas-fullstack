APP_NAME=ATLAS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
# Production: LOG_LEVEL=warning, LOG_CHANNEL=stderr (Railway capture stdout/stderr),
# dan LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter agar log terstruktur
# JSON + konteks request (request_id/user_id/path dari LogRequestContext) bisa
# di-query. Lokal biarkan default (line formatter, lebih enak dibaca).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_STDERR_FORMATTER=Monolog\Formatter\JsonFormatter

# ── Database (PostgreSQL wajib) ───────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=atlas
DB_USERNAME=postgres
DB_PASSWORD=
# Schema aplikasi (search_path). Default app = ptpn_kmr_app — JANGAN 'public'.
DB_SCHEMA=ptpn_kmr_app

# ── Session ───────────────────────────────────────────────────────────────────
# Default 'database' (config/session.php). Wajib di environment dengan filesystem
# ephemeral (Railway, Docker, k8s) — file sessions hilang per redeploy.
# Override ke 'file' hanya di dev untuk debug cepat.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# ── Filesystem ────────────────────────────────────────────────────────────────
# Evidence upload disimpan di storage/app/assignments/ (disk=local)
# Production: pastikan storage/app/ dapat ditulis oleh web server
FILESYSTEM_DISK=local
# Upload disks (scale-readiness S1.4) — MULTI-REPLICA wajib object storage
# (volume lokal tak share-able antar-replica). Saat provision bucket:
#   composer require league/flysystem-aws-s3-v3; isi AWS_*; lalu:
#   UPLOAD_PRIVATE_DISK=s3 ; UPLOAD_PUBLIC_DISK=s3
UPLOAD_PRIVATE_DISK=local
UPLOAD_PUBLIC_DISK=public

# ── Queue ─────────────────────────────────────────────────────────────────────
# Production: QUEUE_CONNECTION=database (php artisan queue:table && migrate)
# sync = blocking, tidak cocok untuk production yang ada job berat
QUEUE_CONNECTION=sync

# ── Cache ─────────────────────────────────────────────────────────────────────
# DEFAULT 'database' (gratis, shared via Postgres antar-replica) — WAJIB untuk
# multi-replica: 'file' per-container bikin cache scope/authz tak konsisten +
# onOneServer scheduler tak jalan + migrate --isolated tak terkunci. Database
# cache butuh tabel cache (migration sudah ada — jalankan `migrate` dulu).
# Upgrade Redis (lebih cepat) = config-flip CACHE_STORE=redis.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# (VITE_REALTIME_SSE dihapus 2026-06-16 — vestigial; SSE sudah di-drop ke
#  polling 2-detik, var ini tak dibaca FE mana pun.)

# Rate limiting web (scale-readiness S2.4) — generous, tak trip pemakaian normal.
# Turunkan bila perlu redam abuse; naikkan bila power-user multi-tab kena 429.
ATLAS_WEB_RATE_LIMIT=600
ATLAS_GUEST_RATE_LIMIT=120
