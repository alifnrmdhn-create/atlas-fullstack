{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently -n \"vite,laravel\" -c \"cyan,green\" \"vite\" \"sh scripts/serve.sh\"",
        "typecheck": "tsc --noEmit --ignoreDeprecations 6.0",
        "audit:routes": "node scripts/audit-frontend-routes.mjs",
        "check": "npm run typecheck && npm run audit:routes && npm run build"
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@inertiajs/react": "^3.0.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "mermaid": "^11.14.0",
        "pdfjs-dist": "^5.6.205",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "recharts": "^3.8.1",
        "typescript": "^6.0.3",
        "zustand": "^5.0.12"
    },
    "overrides": {
        "uuid": "^14.0.0"
    }
}
