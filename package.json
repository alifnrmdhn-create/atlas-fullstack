{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": "22.x"
    },
    "scripts": {
        "build": "vite build",
        "dev": "concurrently --kill-others -n \"vite,laravel\" -c \"cyan,green\" \"sh scripts/vite.sh\" \"sh scripts/serve.sh\"",
        "main-dev": "concurrently --kill-others -n \"vite,laravel\" -c \"cyan,green\" \"vite\" \"php artisan serve --port=8000\"",
        "smoke:browser": "node scripts/browser-smoke.mjs",
        "smoke:workflow": "node scripts/browser-smoke.mjs",
        "typecheck": "tsc --noEmit --ignoreDeprecations 6.0",
        "lint": "eslint resources/js scripts vite.config.ts",
        "audit:routes": "node scripts/audit-frontend-routes.mjs",
        "audit:breakpoints": "node scripts/audit-breakpoints.mjs",
        "check": "npm run typecheck && npm run lint && npm run audit:routes && npm run audit:breakpoints && npm run build"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "concurrently": "^9.0.1",
        "eslint": "^10.4.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "laravel-vite-plugin": "^3.0.0",
        "tailwindcss": "^4.0.0",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@inertiajs/react": "^3.0.3",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "cmdk": "^1.1.1",
        "lucide-react": "^1.14.0",
        "mermaid": "^11.14.0",
        "pdfjs-dist": "^5.6.205",
        "pptxgenjs": "^4.0.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "recharts": "^3.8.1",
        "shepherd.js": "^15.2.2",
        "typescript": "^6.0.3"
    },
    "overrides": {
        "uuid": "^14.0.0",
        "shell-quote": "^1.8.4"
    }
}